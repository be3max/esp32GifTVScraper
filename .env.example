################################################################################
# ESP32 GIF Scraper - Environment Variables
# Copy this file to .env and fill in your actual values
# .env is gitignored and will NOT be committed to GitHub
################################################################################

# ============================================================================
# REQUIRED: API Credentials (you MUST fill these in)
# ============================================================================

# GIPHY API Key
# Get from: https://developers.giphy.com
# Steps: Sign up → Create app → Copy API Key
GIPHY_API_KEY=your_giphy_api_key_here

# GitHub Gist ID
# Get from: https://gist.github.com
# Create a Gist with filename "gif-urls.txt", then copy the ID from the URL
# Example URL: https://gist.github.com/USERNAME/abc123def456
# GIST_ID would be: abc123def456
GIST_ID=your_gist_id_here

# GitHub Personal Access Token
# Get from: GitHub Settings → Developer settings → Personal access tokens → Tokens (classic)
# Steps: Generate new token → name it → select ONLY "gist" scope → copy token
# Token will look like: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GH_TOKEN=your_github_token_here

# ============================================================================
# OPTIONAL: Search Tags (default: 21 retro/pixel art tags)
# ============================================================================

# Comma-separated list of tags to search on GIPHY
# Default: pixel art, retro game, 8bit, arcade, cute, windows 95, windows 98,
#          windows xp, ms-dos, snes, Doom 1, Doom 2, Quake, Quake 2, Quake 3,
#          Unreal Tournament, Half-Life, Half-Life 2, Portal, Diablo 1, Diablo 2
#
# Examples:
#   TAGS=pixel art,pokemon,kirby
#   TAGS=8bit,retro,cute
#   TAGS=windows 95,windows 98
TAGS=pixel art,retro game,8bit,arcade,cute,windows 95,windows 98,windows xp,ms-dos,snes,Doom 1,Doom 2,Quake,Quake 2,Quake 3,Unreal Tournament,Half-Life,Half-Life 2,Portal,Diablo 1,Diablo 2

# ============================================================================
# OPTIONAL: GIF Collection Settings
# ============================================================================

# How many GIFs to fetch from GIPHY per tag (before filtering)
# Default: 50 (max: 100)
# Higher = slower, but more variety to filter from
FETCH_LIMIT=50

# Upper bound for random GIPHY search offset per tag (default: 100)
# Each tag gets a random offset in [0, MAX_OFFSET) so different result pages
# are fetched each run — prevents seeing the same GIFs repeatedly
# Higher = more variety; lower = safer for niche tags with few results
# Examples: 50 (conservative), 100 (default), 200 (popular tags only)
MAX_OFFSET=100

# How many valid GIFs to save to Gist (after filtering)
# Default: 50
# This is the final count that will be written to your Gist
TARGET_COUNT=50

# ============================================================================
# OPTIONAL: GIF Filtering Constraints
# ============================================================================

# Maximum GIF file size in bytes (default: 102400 = 100KB)
# Examples:
#   102400    = 100KB
#   204800    = 200KB
#   262144    = 256KB
#   524288    = 512KB
#   1048576   = 1MB
MAX_SIZE_BYTES=102400

# Maximum GIF width in pixels (default: 200)
# GIFs wider than this will be rejected
# Examples: 150, 200, 256, 300
MAX_WIDTH=200

# Maximum GIF height in pixels (default: 200)
# GIFs taller than this will be rejected
# Examples: 150, 200, 256, 300
MAX_HEIGHT=200

# ============================================================================
# OPTIONAL: Performance & HTTP Settings
# ============================================================================

# Request timeout in milliseconds (default: 10000 = 10 seconds)
# If GIPHY/GitHub APIs are slow, increase this
# Examples: 10000 (10 sec), 15000 (15 sec), 20000 (20 sec)
REQUEST_TIMEOUT=10000

# Number of parallel HEAD requests when checking GIF sizes (default: 10)
# Higher = faster (more parallel), but more aggressive on CDN
# Lower = slower, but less aggressive
# Recommended: 5-20 depending on network
# Examples: 5, 10, 15, 20
CONCURRENCY=10

################################################################################
# Notes:
# - REQUIRED vars (GIPHY_API_KEY, GIST_ID, GITHUB_TOKEN) are validated at
#   startup and will cause an error if missing
# - OPTIONAL vars use the defaults shown above if not set
# - TAGS is comma-separated with NO spaces around commas
#   ✓ Correct:   TAGS=pixel art,retro game,8bit
#   ✗ Incorrect: TAGS=pixel art, retro game, 8bit (spaces will break it)
# - File size is in bytes. Use the examples above or calculate:
#   bytes = KB * 1024 (e.g., 256KB = 256 * 1024 = 262144)
# - This file .env is NEVER committed to git (it's in .gitignore)
################################################################################
